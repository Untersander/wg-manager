# WireGuard Client Configuration Example
# This file should be created on the client device

[Interface]
# Client private key (generate with: wg genkey)
PrivateKey = <REPLACE_WITH_CLIENT_PRIVATE_KEY>

# Client IP addresses (assigned by server)
Address = 10.0.0.2/32, fd00::2/128

# DNS servers (optional)
DNS = 1.1.1.1, 2606:4700:4700::1111

[Peer]
# Server's public key (get from: wg pubkey < server-private.key)
PublicKey = <REPLACE_WITH_SERVER_PUBLIC_KEY>

# Server endpoint (IP:port)
Endpoint = <SERVER_IP_OR_HOSTNAME>:51820

# Routes to send through VPN
# For all traffic through VPN (full tunnel):
AllowedIPs = 0.0.0.0/0, ::/0

# For split tunnel (only specific networks):
# AllowedIPs = 10.0.0.0/24, fd00::/64

# Keep connection alive (recommended for clients behind NAT)
PersistentKeepalive = 25
